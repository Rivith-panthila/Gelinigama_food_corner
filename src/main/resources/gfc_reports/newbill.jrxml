<jasperReport name="newbill" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="580c0f27-8b1a-4e1b-9ecc-ebeb05e904b9">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CopyOfMYSQL-gelanigama_food_corner"/>
	<parameter name="order_id" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
    o.order_id            AS order_id,
    o.order_contact       AS order_contact,
    o.order_type          AS order_type,
    o.customer_id         AS customer_id,
    o.order_date          AS order_date,
    o.discount            AS discount,
    o.total               AS order_total,   -- ✅ orders table total

    oi.item_id            AS item_id,
    oi.quantity           AS quantity,
    oi.unit_price         AS unit_price,
    oi.line_total         AS line_total,

    fi.item_name          AS item_name,

    p.payment_method      AS payment_method,
    p.paid_amount         AS paid_amount,
    p.balance             AS balance

FROM orders o
JOIN order_items oi 
    ON o.order_id = oi.order_id
JOIN food_item fi 
    ON oi.item_id = fi.item_id
LEFT JOIN payment p 
    ON o.order_id = p.order_id

WHERE o.order_id = $P{order_id}
]]></query>
